# =============================================================================
# Home Lab — Environment Variables
# =============================================================================
# Copy this file to .env and fill in the values.
# NEVER commit .env to git — it contains secrets!
# =============================================================================

# --- General ---
TZ=Europe/Paris
DOMAIN=example.com
PI_LAN_IP=192.168.1.X  # TODO: your Pi's LAN IP

# --- Storage paths ---
SERVICES_DATA_DIR=/mnt/data/services
MEDIA_DIR=/mnt/data/media

# --- Traefik ---
TRAEFIK_ACME_EMAIL=  # TODO: email for Let's Encrypt

# --- Pi-hole ---
PIHOLE_PASSWORD=  # TODO: generate a strong password

# --- WireGuard ---
WG_HOST=  # TODO: your public IP or DynDNS hostname
WG_PASSWORD_HASH=  # TODO: generate with: wg-easy password hash

# --- Nextcloud ---
NEXTCLOUD_ADMIN_USER=admin
NEXTCLOUD_ADMIN_PASSWORD=  # TODO: generate a strong password
NEXTCLOUD_DB_NAME=nextcloud
NEXTCLOUD_DB_USER=nextcloud
NEXTCLOUD_DB_PASSWORD=  # TODO: generate a strong password
NEXTCLOUD_DB_ROOT_PASSWORD=  # TODO: generate a strong password

# --- Vaultwarden ---
VAULTWARDEN_ADMIN_TOKEN=  # TODO: generate with: openssl rand -base64 48
VAULTWARDEN_SIGNUPS_ALLOWED=false

# --- Immich ---
IMMICH_DB_USER=immich
IMMICH_DB_PASSWORD=  # TODO: generate a strong password
IMMICH_DB_NAME=immich

# --- HedgeDoc ---
HEDGEDOC_DB_USER=hedgedoc
HEDGEDOC_DB_PASSWORD=  # TODO: generate a strong password
HEDGEDOC_DB_NAME=hedgedoc
