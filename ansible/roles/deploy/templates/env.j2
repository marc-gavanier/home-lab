# =============================================================================
# Home Lab — Environment Variables (generated by Ansible)
# =============================================================================
# Note: $ characters are escaped as $$ for Docker Compose compatibility
{% set esc = {'fn': '$'} %}

# --- General ---
TZ=Europe/Paris
DOMAIN={{ domain }}
PI_LAN_IP={{ homelab_ip }}

# --- Storage paths ---
SERVICES_DATA_DIR={{ services_data_dir }}
MEDIA_DIR={{ media_dir }}

# --- Traefik ---
TRAEFIK_ACME_EMAIL={{ traefik_acme_email }}

# --- Pi-hole ---
PIHOLE_PASSWORD={{ pihole_password | replace('$', '$$') }}

# --- WireGuard ---
WG_HOST=vpn.{{ domain }}
WG_PASSWORD_HASH={{ wg_password_hash | replace('$', '$$') }}

# --- Nextcloud ---
NEXTCLOUD_ADMIN_USER={{ nextcloud_admin_user | default('admin') }}
NEXTCLOUD_ADMIN_PASSWORD={{ nextcloud_admin_password | replace('$', '$$') }}
NEXTCLOUD_DB_NAME={{ nextcloud_db_name | default('nextcloud') }}
NEXTCLOUD_DB_USER={{ nextcloud_db_user | default('nextcloud') }}
NEXTCLOUD_DB_PASSWORD={{ nextcloud_db_password | replace('$', '$$') }}
NEXTCLOUD_DB_ROOT_PASSWORD={{ nextcloud_db_root_password | replace('$', '$$') }}

# --- Vaultwarden ---
VAULTWARDEN_ADMIN_TOKEN={{ vaultwarden_admin_token | replace('$', '$$') }}
VAULTWARDEN_SIGNUPS_ALLOWED=false

# --- Immich ---
IMMICH_DB_USER={{ immich_db_user | default('immich') }}
IMMICH_DB_PASSWORD={{ immich_db_password | replace('$', '$$') }}
IMMICH_DB_NAME={{ immich_db_name | default('immich') }}

# --- HedgeDoc ---
HEDGEDOC_DB_USER={{ hedgedoc_db_user | default('hedgedoc') }}
HEDGEDOC_DB_PASSWORD={{ hedgedoc_db_password | replace('$', '$$') }}
HEDGEDOC_DB_NAME={{ hedgedoc_db_name | default('hedgedoc') }}
